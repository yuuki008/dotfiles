#!/bin/sh

set -e

DOTFILES_DIR="$(pwd)"
cd "$HOME"

# ==================================================
# 設定ファイル（シンボリックリンク）
# ==================================================
ln -sf "$DOTFILES_DIR/.hushlogin" ~/.hushlogin
ln -sf "$DOTFILES_DIR/.gitconfig" ~/.gitconfig
ln -sf "$DOTFILES_DIR/.zprofile" ~/.zprofile
ln -sf "$DOTFILES_DIR/.zshrc" ~/.zshrc

ln -sf "$DOTFILES_DIR/.config/starship.toml" ~/.config/starship.toml

ln -sf "$HOME/dotfiles/.config/tmux/tmux.conf" "$HOME/.tmux.conf"
ln -sf "$HOME/dotfiles/.config/tmux/tmux.conf.osx" "$HOME/.tmux.conf.osx"
ln -sf "$HOME/dotfiles/.config/tmux/tmux.powerline.conf" "$HOME/.tmux.powerline.conf"

# nvimはディレクトリ全体をシンボリックリンク
if [ -d ~/.config/nvim ] && [ ! -L ~/.config/nvim ]; then
    rm -rf ~/.config/nvim
fi
ln -sfn "$DOTFILES_DIR/.config/nvim" ~/.config/nvim

# Claude Code設定（ファイル単位でリンク、他のファイルは残す）
ln -sf "$DOTFILES_DIR/.claude/CLAUDE.md" ~/.claude/CLAUDE.md
ln -sf "$DOTFILES_DIR/.claude/settings.json" ~/.claude/settings.json
ln -sf "$DOTFILES_DIR/.claude/statusline.sh" ~/.claude/statusline.sh
chmod +x "$DOTFILES_DIR/.claude/statusline.sh"
ln -sfn "$DOTFILES_DIR/.claude/scripts" ~/.claude/scripts

# skillsはディレクトリ全体をシンボリックリンク
if [ -d ~/.claude/skills ] && [ ! -L ~/.claude/skills ]; then
    rm -rf ~/.claude/skills
fi
ln -sfn "$DOTFILES_DIR/.claude/skills" ~/.claude/skills

echo "Setup complete! Run 'source ~/.zshrc' to apply changes."
